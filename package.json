{
  "name": "rachana",
  "private": true,
  "version": "0.2.1",
  "description": "A private, local-first workspace for visual thinking.",
  "author": "Rachana Contributors",
  "desktopName": "Rachana.desktop",
  "engines": {
    "node": ">=26"
  },
  "packageManager": "npm@11.17.0",
  "main": "out/main/index.js",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:electron": "npm run build && playwright test --config playwright.config.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "release:mac": "npm run build && electron-builder --mac dmg",
    "mas:build": "npm run build && electron-builder --mac mas",
    "mas:upload": "node scripts/upload-mas.mjs"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-tooltip": "^1.2.10",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@excalidraw/excalidraw": {
      "@radix-ui/react-tabs": "1.1.15",
      "nanoid": "3.3.13"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "@mermaid-js/parser": "1.1.1",
      "nanoid": "5.1.14"
    },
    "lodash-es": "4.18.1"
  }
}
